# ── Frontend ──────────────────────────────────
# Copy to frontend/.env and fill in real values
VITE_API_BASE_URL=http://localhost:8080

# Firebase (from Firebase Console → Project Settings → Your apps)
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=ecoquest-app.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=ecoquest-app
VITE_FIREBASE_STORAGE_BUCKET=ecoquest-app.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_MEASUREMENT_ID
