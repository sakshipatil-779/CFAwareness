# EcoQuest — .gitignore

# ── Node ─────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.pnpm-store

# ── Build outputs ─────────────────────────────────────────────────
dist/
build/
.vite/

# ── Environment variables ─────────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# IMPORTANT: never commit real secrets
backend/serviceAccountKey.json

# ── Coverage ──────────────────────────────────────────────────────
coverage/
*.lcov

# ── Editor / IDE ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── TypeScript ────────────────────────────────────────────────────
*.js.map
*.tsbuildinfo

# ── Firebase ──────────────────────────────────────────────────────
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log

# ── Logs ─────────────────────────────────────────────────────────
logs/
*.log
