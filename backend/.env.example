# ── EcoQuest Backend — Environment Variables ──────────────────────────────
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Server ────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
ALLOWED_ORIGIN=http://localhost:5173

# ── Google Cloud Project ──────────────────────────────────────────────────
# Your GCP project ID (used for Vertex AI / ADC authentication)
GOOGLE_CLOUD_PROJECT_ID=sakshi-promptwar3

# Region where Veo 3.1 is available (must be us-central1 for Veo)
GOOGLE_CLOUD_LOCATION=us-central1

# ── Gemini API (for Gemini Flash + Veo via AI Studio key) ─────────────────
# Get from: https://aistudio.google.com/app/apikey
# Required for Gemini analysis AND Veo 3.1 video generation
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Veo 3.1 Video Generation ──────────────────────────────────────────────
# Model ID for Veo — check Vertex AI Model Garden for latest
VEO_MODEL=veo-3.1-generate-preview

# GCS bucket for storing generated videos (separate from audio for access control)
# Create with: gsutil mb -l US-CENTRAL1 gs://your-project-videos
GCS_VIDEO_BUCKET=sakshi-promptwar3-videos

# ── Google Cloud Storage (for TTS audio files) ────────────────────────────
# GCS bucket for TTS narration audio
# Create with: gsutil mb gs://your-project-tts-audio
GCS_BUCKET_NAME=sakshi-promptwar3-tts-audio

# ── Google Cloud Text-to-Speech ───────────────────────────────────────────
# Uses Application Default Credentials (ADC) — no separate key needed on Cloud Run
# For local dev, run: gcloud auth application-default login

# ── Google Cloud Translation API ──────────────────────────────────────────
TRANSLATION_API_KEY=YOUR_TRANSLATION_API_KEY_HERE

# ── Firebase Admin SDK ────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# ── GCP Setup Checklist ───────────────────────────────────────────────────
# Enable these APIs in your GCP project:
#   gcloud services enable aiplatform.googleapis.com
#   gcloud services enable texttospeech.googleapis.com
#   gcloud services enable storage.googleapis.com
#   gcloud services enable translate.googleapis.com
#
# Create GCS buckets with uniform access control:
#   gsutil mb -l US-CENTRAL1 gs://$GCS_VIDEO_BUCKET
#   gsutil mb -l US gs://$GCS_BUCKET_NAME
#   gsutil uniformbucketlevelaccess set on gs://$GCS_VIDEO_BUCKET
#   gsutil uniformbucketlevelaccess set on gs://$GCS_BUCKET_NAME
#
# Grant service account permissions:
#   gcloud projects add-iam-policy-binding $GOOGLE_CLOUD_PROJECT_ID \
#     --member="serviceAccount:YOUR_SA@$GOOGLE_CLOUD_PROJECT_ID.iam.gserviceaccount.com" \
#     --role="roles/storage.objectAdmin"
#   gcloud projects add-iam-policy-binding $GOOGLE_CLOUD_PROJECT_ID \
#     --member="serviceAccount:YOUR_SA@$GOOGLE_CLOUD_PROJECT_ID.iam.gserviceaccount.com" \
#     --role="roles/aiplatform.user"
